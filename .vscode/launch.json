{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ticketly (Web HTML Renderer)",
      "request": "launch",
      "type": "dart",
      "args": [
        "--web-renderer",
        "html"
      ]
    },
    {
      "name": "ticketly (Web Disable Security)",
      "request": "launch",
      "type": "dart",
      "args": [
        "--web-browser-flag",
        "--disable-web-security"
      ]
    }
  ]
}
